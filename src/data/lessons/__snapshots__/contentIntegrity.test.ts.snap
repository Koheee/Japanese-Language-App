  {
    "dialogue": [
      {
        "english": "Are the preparations for the garden done yet?",
        "grammarIds": [],
        "id": "l24-d01",
        "japanese": "にわの じゅんびは もう できましたか。",
        "speaker": "Kei",
      },
      {
        "english": "It is mostly done. Sota brought the tools for us.",
        "grammarIds": [
          "l24-te-kureru",
        ],
        "id": "l24-d02",
        "japanese": "だいたい できました。ソウタさんが どうぐを もってきてくれました。",
        "speaker": "Mina",
      },
      {
        "english": "Great. I had Aya teach me how to plant vegetables.",
        "grammarIds": [
          "l24-te-morau",
        ],
        "id": "l24-d03",
        "japanese": "よかった。わたしは アヤさんに やさいの うえかたを おしえてもらいました。",
        "speaker": "Kei",
      },
      {
        "english": "I’ll carry that large box for you.",
        "grammarIds": [
          "l24-te-ageru",
        ],
        "id": "l24-d04",
        "japanese": "その おおきい はこは、わたしが はこんであげます。",
        "speaker": "Mina",
      },
      {
        "english": "Thanks. Then I’ll put up your sign for you.",
        "grammarIds": [
          "l24-te-ageru",
        ],
        "id": "l24-d05",
        "japanese": "ありがとう。じゃあ、わたしは ミナさんの かんばんを つけてあげます。",
        "speaker": "Kei",
      },
      {
        "english": "That helps. A neighbor repaired the bench for us too. Let’s thank everyone.",
        "grammarIds": [
          "l24-te-kureru",
        ],
        "id": "l24-d06",
        "japanese": "たすかります。きんじょの かたも ベンチを なおしてくれました。みんなに おれいを いいましょう。",
        "speaker": "Mina",
      },
    ],
