  {
    "dialogue": [
      {
        "english": "Oh, where is the room key?",
        "grammarIds": [
          "l10-known-location",
        ],
        "id": "l10-d01",
        "japanese": "あれ、へやの かぎは どこに ありますか。",
        "speaker": "Mina",
      },
      {
        "english": "It is on the shelf in the entryway.",
        "grammarIds": [
          "l10-position-words",
        ],
        "id": "l10-d02",
        "japanese": "げんかんの たなの うえに ありますよ。",
        "speaker": "Leo",
      },
      {
        "english": "It is not there. There is a cat on the shelf.",
        "grammarIds": [
          "l10-place-new-entity",
          "l10-existence-verbs",
        ],
        "id": "l10-d03",
        "japanese": "ありません。たなの うえに ねこが います。",
        "speaker": "Mina",
      },
      {
        "english": "Really? Then, how about under the sofa?",
        "grammarIds": [],
        "id": "l10-d04",
        "japanese": "ほんとうですか。じゃ、ソファの したは？",
        "speaker": "Leo",
      },
      {
        "english": "There is a remote under the sofa, but the key is not there.",
        "grammarIds": [
          "l10-place-new-entity",
          "l10-position-words",
        ],
        "id": "l10-d05",
        "japanese": "ソファの したに リモコンが あります。でも、かぎは ありません。",
        "speaker": "Mina",
      },
      {
        "english": "Oh, it is inside my pocket. Sorry.",
        "grammarIds": [
          "l10-known-location",
          "l10-position-words",
        ],
        "id": "l10-d06",
        "japanese": "あ、わたしの ポケットの なかに あります。ごめんなさい。",
        "speaker": "Leo",
      },
    ],
    "exerciseIds": [
      "l10-e01",
      "l10-e02",
      "l10-e03",
      "l10-e04",
      "l10-e05",
      "l10-e06",
      "l10-e07",
      "l10-e08",
    ],
    "lessonId": "lesson-10",
  },
  {
    "dialogue": [
      {
        "english": "Welcome. What are you sending today?",
        "grammarIds": [],
        "id": "l11-d01",
        "japanese": "いらっしゃいませ。きょうは 何を おくりますか。",
        "speaker": "Clerk",
      },
      {
        "english": "I am sending these three postcards and one parcel.",
        "grammarIds": [
          "l11-counters",
        ],
        "id": "l11-d02",
        "japanese": "この はがきを さんまいと、にもつを ひとつ おくります。",
        "speaker": "Kai",
      },
      {
        "english": "How many stamps do you need?",
        "grammarIds": [
          "l11-quantity-questions",
        ],
        "id": "l11-d03",
        "japanese": "きっては 何まい いりますか。",
        "speaker": "Clerk",
      },
      {
        "english": "Three, please. About how long will the parcel take to Singapore?",
        "grammarIds": [
          "l11-quantity-questions",
        ],
        "id": "l11-d04",
        "japanese": "さんまい おねがいします。にもつは シンガポールまで どのくらい かかりますか。",
        "speaker": "Kai",
      },
      {
        "english": "It takes about five days.",
        "grammarIds": [
          "l11-duration",
        ],
        "id": "l11-d05",
        "japanese": "だいたい 五日 かかります。",
        "speaker": "Clerk",
      },
      {
        "english": "Got it. I send a parcel to this club four times a year. Please process everything, then.",
        "grammarIds": [
          "l11-frequency",
        ],
        "id": "l11-d06",
        "japanese": "わかりました。この クラブへ 一年に 四回 にもつを おくります。では、ぜんぶ おねがいします。",
        "speaker": "Kai",
      },
    ],
    "exerciseIds": [
      "l11-e01",
      "l11-e02",
      "l11-e03",
      "l11-e04",
      "l11-e05",
      "l11-e06",
      "l11-e07",
      "l11-e08",
    ],
    "lessonId": "lesson-11",
  },
  {
    "dialogue": [
      {
        "english": "How was last week’s mountain trip?",
        "grammarIds": [],
        "id": "l12-d01",
        "japanese": "先週の 山の りょこうは どうでしたか。",
        "speaker": "Rina",
      },
      {
        "english": "It was great fun. The scenery was beautiful too.",
        "grammarIds": [
          "l12-i-adjective-past",
          "l12-na-noun-past",
        ],
        "id": "l12-d02",
        "japanese": "とても たのしかったです。けしきも きれいでした。",
        "speaker": "Owen",
      },
      {
        "english": "But the weather was not very good, was it?",
        "grammarIds": [
          "l12-i-adjective-past",
        ],
        "id": "l12-d03",
        "japanese": "でも、てんきは あまり よくなかったですね。",
        "speaker": "Rina",
      },
      {
        "english": "Right. But the mountains were cooler than the seaside.",
        "grammarIds": [
          "l12-yori-comparison",
        ],
        "id": "l12-d04",
        "japanese": "ええ。でも、山は うみより すずしかったです。",
        "speaker": "Owen",
      },
      {
        "english": "Which do you prefer, the mountains or the seaside?",
        "grammarIds": [
          "l12-choice-best",
        ],
        "id": "l12-d05",
        "japanese": "山と うみと どちらが すきですか。",
        "speaker": "Rina",
      },
      {
        "english": "I prefer the mountains. In particular, the mountains are most beautiful in autumn.",
        "grammarIds": [
          "l12-choice-best",
        ],
        "id": "l12-d06",
        "japanese": "山の ほうが すきです。とくに、秋の 山が いちばん きれいです。",
        "speaker": "Owen",
      },
    ],
    "exerciseIds": [
      "l12-e01",
      "l12-e02",
      "l12-e03",
      "l12-e04",
      "l12-e05",
      "l12-e06",
      "l12-e07",
      "l12-e08",
    ],
    "lessonId": "lesson-12",
  },
  {
    "dialogue": [
      {
        "english": "Do you want to go somewhere on Saturday?",
        "grammarIds": [
          "l13-indefinites",
          "l13-tai",
        ],
        "id": "l13-d01",
        "japanese": "土曜日、どこかへ 行きたいですか。",
        "speaker": "Aya",
      },
      {
        "english": "Yes. I want to go to the market by the river.",
        "grammarIds": [
          "l13-tai",
        ],
        "id": "l13-d02",
        "japanese": "はい。川の そばの 市場へ 行きたいです。",
        "speaker": "Ben",
      },
      {
        "english": "What will you go to the market to do?",
        "grammarIds": [
          "l13-purpose-movement",
        ],
        "id": "l13-d03",
        "japanese": "市場へ 何を しに 行きますか。",
        "speaker": "Aya",
      },
      {
        "english": "I am going to look for a gift for my younger sister. I want a handmade wallet.",
        "grammarIds": [
          "l13-purpose-movement",
          "l13-hoshii",
        ],
        "id": "l13-d04",
        "japanese": "妹の おみやげを さがしに 行きます。てづくりの さいふが ほしいです。",
        "speaker": "Ben",
      },
      {
        "english": "I want to see the pottery. Then let’s eat something.",
        "grammarIds": [
          "l13-tai",
          "l13-indefinites",
        ],
        "id": "l13-d05",
        "japanese": "わたしは やきものを 見たいです。それから、何か 食べましょう。",
        "speaker": "Aya",
      },
      {
        "english": "Sounds good. I am hungry, so let’s also go to the market to eat lunch.",
        "grammarIds": [
          "l13-purpose-movement",
        ],
        "id": "l13-d06",
        "japanese": "いいですね。おなかが すきましたから、市場へ 昼ごはんも 食べに 行きましょう。",
        "speaker": "Ben",
      },
    ],
    "exerciseIds": [
      "l13-e01",
      "l13-e02",
      "l13-e03",
      "l13-e04",
      "l13-e05",
      "l13-e06",
      "l13-e07",
      "l13-e08",
    ],
    "lessonId": "lesson-13",
  },
  {
    "dialogue": [
      {
        "english": "I am putting a poster up at the entrance now. Please hold that side.",
        "grammarIds": [
          "l14-action-progress",
          "l14-request",
        ],
        "id": "l14-d01",
        "japanese": "今、入口に ポスターを はっています。そちらを もってください。",
        "speaker": "Sora",
      },
      {
        "english": "Okay. A little higher?",
        "grammarIds": [],
        "id": "l14-d02",
        "japanese": "はい。もう 少し 上ですか。",
        "speaker": "Nina",
      },
      {
        "english": "Yes, please raise it slowly.",
        "grammarIds": [
          "l14-request",
        ],
        "id": "l14-d03",
        "japanese": "ええ、ゆっくり 上げてください。",
        "speaker": "Sora",
      },
      {
        "english": "Got it. Shall I arrange the chairs next?",
        "grammarIds": [
          "l14-offer",
        ],
        "id": "l14-d04",
        "japanese": "わかりました。つぎは いすを ならべましょうか。",
        "speaker": "Nina",
      },
      {
        "english": "Please do. Ken is carrying tables in the next room.",
        "grammarIds": [
          "l14-action-progress",
        ],
        "id": "l14-d05",
        "japanese": "お願いします。ケンさんが となりの へやで つくえを はこんでいます。",
        "speaker": "Sora",
      },
      {
        "english": "The room is dark. Shall I turn on the light?",
        "grammarIds": [
          "l14-offer",
        ],
        "id": "l14-d06",
        "japanese": "へやが くらいですね。でんきを つけましょうか。",
        "speaker": "Nina",
      },
      {
        "english": "Yes, please turn it on. Thank you.",
        "grammarIds": [
          "l14-request",
        ],
        "id": "l14-d07",
        "japanese": "ええ、つけてください。ありがとうございます。",
        "speaker": "Sora",
      },
    ],
    "exerciseIds": [
      "l14-e01",
      "l14-e02",
      "l14-e03",
      "l14-e04",
      "l14-e05",
      "l14-e06",
