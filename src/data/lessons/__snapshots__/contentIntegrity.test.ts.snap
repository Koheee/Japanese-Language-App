  {
    "dialogue": [
      {
        "english": "Sam, have you ever climbed Mount Midori?",
        "grammarIds": [
          "l19-experience",
        ],
        "id": "l19-d01",
        "japanese": "サムさんは みどり山に のぼったことが ありますか。",
        "speaker": "Mika",
      },
      {
        "english": "No, I haven’t. But I have stayed in a tent.",
        "grammarIds": [
          "l19-experience",
        ],
        "id": "l19-d02",
        "japanese": "いいえ、ありません。でも、テントに とまったことは あります。",
        "speaker": "Sam",
      },
      {
        "english": "Would you like to go together this weekend?",
        "grammarIds": [],
        "id": "l19-d03",
        "japanese": "こんどの しゅうまつ、いっしょに いきませんか。",
        "speaker": "Mika",
      },
      {
        "english": "Sounds good. What will we do in the mountains?",
        "grammarIds": [],
        "id": "l19-d04",
        "japanese": "いいですね。山で なにを しますか。",
        "speaker": "Sam",
      },
      {
        "english": "We’ll do things like walk in the woods and photograph the scenery.",
        "grammarIds": [
          "l19-representative-actions",
        ],
        "id": "l19-d05",
        "japanese": "もりを あるいたり、けしきの しゃしんを とったり します。",
        "speaker": "Mika",
      },
      {
        "english": "I’m looking forward to it. I’ve become physically stronger recently.",
        "grammarIds": [
          "l19-change",
        ],
        "id": "l19-d06",
        "japanese": "たのしみです。さいきん からだが つよく なりました。",
        "speaker": "Sam",
      },
    ],
    "exerciseIds": [
      "l19-e01",
      "l19-e02",
      "l19-e03",
      "l19-e04",
      "l19-e05",
      "l19-e06",
      "l19-e07",
      "l19-e08",
    ],
    "lessonId": "lesson-19",
  },
  {
    "dialogue": [
      {
        "english": "Are you free tomorrow evening?",
        "grammarIds": [
          "l20-casual-questions",
          "l20-plain-descriptions",
        ],
        "id": "l20-d01",
        "japanese": "あしたの よる、ひま？",
        "speaker": "Riku",
      },
      {
        "english": "Yeah, I’m free. What’s up?",
        "grammarIds": [
          "l20-final-particles",
        ],
        "id": "l20-d02",
        "japanese": "うん、ひまだよ。どうしたの？",
        "speaker": "Nora",
      },
      {
        "english": "We’re playing board games at my place. Are you coming too?",
        "grammarIds": [
          "l20-plain-verbs",
          "l20-casual-questions",
        ],
        "id": "l20-d03",
        "japanese": "うちで ボードゲームを する。ノラも くる？",
        "speaker": "Riku",
      },
      {
        "english": "I’ll come! Who’s coming?",
        "grammarIds": [
          "l20-casual-questions",
        ],
        "id": "l20-d04",
        "japanese": "いく！ だれが くる？",
        "speaker": "Nora",
      },
      {
        "english": "Yu and Mei are coming. The games aren’t difficult, you know.",
        "grammarIds": [
          "l20-plain-descriptions",
          "l20-final-particles",
        ],
        "id": "l20-d05",
        "japanese": "ユウと メイが くるよ。ゲームは むずかしくないよ。",
        "speaker": "Riku",
      },
      {
        "english": "Great. Then I’ll bring snacks, okay?",
        "grammarIds": [
          "l20-final-particles",
        ],
        "id": "l20-d06",
        "japanese": "よかった。じゃ、おかしを もっていくね。",
        "speaker": "Nora",
      },
    ],
    "exerciseIds": [
