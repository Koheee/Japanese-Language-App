  {
    "dialogue": [
      {
        "english": "Who is the person over there wearing a blue hat?",
        "grammarIds": [
          "l22-relative-clause",
        ],
        "id": "l22-d01",
        "japanese": "あそこで あおい ぼうしを かぶっている ひとは だれですか。",
        "speaker": "Hana",
      },
      {
        "english": "That is Mio, who makes artwork in this studio.",
        "grammarIds": [
          "l22-relative-clause",
        ],
        "id": "l22-d02",
        "japanese": "この スタジオで さくひんを つくっている ミオさんです。",
        "speaker": "Ken",
      },
      {
        "english": "This plate that Mio made is light, isn’t it?",
        "grammarIds": [
          "l22-inner-subject",
        ],
        "id": "l22-d03",
        "japanese": "ミオさんが つくった この さらは かるいですね。",
        "speaker": "Hana",
      },
      {
        "english": "Yes. There are also plates that have not been painted yet.",
        "grammarIds": [
          "l22-tense-negative",
        ],
        "id": "l22-d04",
        "japanese": "ええ。まだ いろを ぬっていない さらも あります。",
        "speaker": "Ken",
      },
      {
        "english": "I want time to make art too.",
        "grammarIds": [
          "l22-time-for-action",
        ],
        "id": "l22-d05",
        "japanese": "わたしも さくひんを つくる じかんが ほしいです。",
        "speaker": "Hana",
      },
      {
        "english": "Next door there is a room with large windows. I’ll show it to you next time.",
        "grammarIds": [
          "l22-inner-subject",
        ],
        "id": "l22-d06",
        "japanese": "となりに まどが おおきい へやが あります。こんど しょうかいしますよ。",
        "speaker": "Ken",
      },
    ],
    "exerciseIds": [
      "l22-e01",
