  {
    "dialogue": [
      {
        "english": "I’m transferring to Osaka next month.",
        "grammarIds": [],
        "id": "l25-d01",
        "japanese": "らいげつ、おおさかへ てんきんします。",
        "speaker": "Aya",
      },
      {
        "english": "I see. When you arrive in Osaka, what will you do first?",
        "grammarIds": [
          "l25-after-tara",
        ],
        "id": "l25-d02",
        "japanese": "そうですか。おおさかに ついたら、まず なにを しますか。",
        "speaker": "Ben",
      },
      {
        "english": "Once the move is finished, I’ll walk around the neighborhood.",
        "grammarIds": [
          "l25-after-tara",
        ],
        "id": "l25-d03",
        "japanese": "ひっこしが おわったら、ちかくを あるきます。",
        "speaker": "Aya",
      },
      {
        "english": "Even if work is busy, please send photos.",
        "grammarIds": [
          "l25-even-if",
        ],
        "id": "l25-d04",
        "japanese": "しごとが いそがしくても、しゃしんを おくってくださいね。",
        "speaker": "Ben",
      },
      {
        "english": "Of course. If you happen to be free on a weekend, please come visit.",
        "grammarIds": [
          "l25-moshi",
          "l25-tara-condition",
        ],
        "id": "l25-d05",
        "japanese": "もちろん。もし しゅうまつ ひまだったら、あそびに きてください。",
        "speaker": "Aya",
      },
      {
        "english": "Yes. Even if we live in different cities, I’ll definitely stay in touch.",
        "grammarIds": [
          "l25-even-if",
        ],
        "id": "l25-d06",
        "japanese": "はい。べつべつの まちに すんでも、かならず れんらくします。",
        "speaker": "Ben",
      },
    ],
