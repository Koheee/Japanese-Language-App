  {
    "dialogue": [
      {
        "english": "What do you think about the upcoming eco-fair?",
        "grammarIds": [
          "l21-topic-about",
          "l21-think",
        ],
        "id": "l21-d01",
        "japanese": "こんどの エコフェアについて、どう おもいますか。",
        "speaker": "Emi",
      },
      {
        "english": "I think it is an interesting plan.",
        "grammarIds": [
          "l21-think",
        ],
        "id": "l21-d02",
        "japanese": "おもしろい けいかくだと おもいます。",
        "speaker": "Jon",
      },
      {
        "english": "The weather forecast said it would be sunny on Saturday.",
        "grammarIds": [
          "l21-say",
        ],
        "id": "l21-d03",
        "japanese": "てんきよほうで、どようびは はれると いっていました。",
        "speaker": "Emi",
      },
      {
        "english": "Then a lot of people will probably come.",
        "grammarIds": [
          "l21-probability",
        ],
        "id": "l21-d04",
        "japanese": "じゃあ、たくさんの ひとが くるでしょう。",
        "speaker": "Jon",
      },
      {
        "english": "The staff said, “Please bring your own bottle.”",
        "grammarIds": [
          "l21-say",
        ],
        "id": "l21-d05",
        "japanese": "スタッフは「マイボトルを もってきてください」と いいました。",
        "speaker": "Emi",
      },
      {
        "english": "Good idea. I think we can reduce waste.",
        "grammarIds": [
          "l21-think",
        ],
        "id": "l21-d06",
        "japanese": "いいですね。ごみを へらすことが できると おもいます。",
        "speaker": "Jon",
      },
    ],
    "exerciseIds": [
      "l21-e01",
      "l21-e02",
      "l21-e03",
      "l21-e04",
      "l21-e05",
      "l21-e06",
      "l21-e07",
      "l21-e08",
    ],
    "lessonId": "lesson-21",
