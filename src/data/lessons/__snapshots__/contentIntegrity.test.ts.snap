      "l14-e08",
    ],
    "lessonId": "lesson-14",
  },
  {
    "dialogue": [
      {
        "english": "Excuse me. May I use this lounge?",
        "grammarIds": [
          "l15-permission",
        ],
        "id": "l15-d01",
        "japanese": "すみません。この ラウンジを つかっても いいですか。",
        "speaker": "Iris",
      },
      {
        "english": "Yes, members may use it. Please show your membership card.",
        "grammarIds": [
          "l15-permission",
        ],
        "id": "l15-d02",
        "japanese": "はい、会員は つかっても いいです。会員カードを 見せてください。",
        "speaker": "Staff",
      },
      {
        "english": "Here you are. May I drink coffee here?",
        "grammarIds": [
          "l15-permission",
        ],
        "id": "l15-d03",
        "japanese": "どうぞ。ここで コーヒーを のんでも いいですか。",
        "speaker": "Iris",
      },
      {
        "english": "I am sorry, but you must not drink coffee or eat food in this room. Please use the break room.",
        "grammarIds": [
          "l15-prohibition",
        ],
        "id": "l15-d04",
        "japanese": "ざんねんですが、この へやで コーヒーを のんでは いけません。食べものも 食べては いけません。休けい室を つかってください。",
        "speaker": "Staff",
      },
      {
        "english": "Understood. Does Mina work here too?",
        "grammarIds": [
          "l15-continuing-state",
        ],
        "id": "l15-d05",
        "japanese": "わかりました。ミナさんも ここで 働いていますか。",
        "speaker": "Iris",
      },
      {
        "english": "Yes. Do you know Mina?",
        "grammarIds": [
          "l15-knowing",
        ],
        "id": "l15-d06",
        "japanese": "はい。ミナさんを 知っていますか。",
        "speaker": "Staff",
      },
      {
        "english": "Yes, I know her. We live in the same town.",
        "grammarIds": [
          "l15-knowing",
          "l15-continuing-state",
        ],
        "id": "l15-d07",
        "japanese": "はい、知っています。同じ 町に 住んでいます。",
        "speaker": "Iris",
      },
    ],
    "exerciseIds": [
      "l15-e01",
      "l15-e02",
      "l15-e03",
      "l15-e04",
      "l15-e05",
      "l15-e06",
      "l15-e07",
      "l15-e08",
    ],
    "lessonId": "lesson-15",
  },
  {
    "dialogue": [
      {
        "english": "Excuse me. How do I become a member of this gym?",
        "grammarIds": [
          "l16-how-to",
        ],
        "id": "l16-d01",
        "japanese": "すみません。どうやって この ジムの 会員に なりますか。",
        "speaker": "Tariq",
      },
      {
        "english": "Get this form at reception and write your name and address.",
        "grammarIds": [
          "l16-action-sequence",
        ],
        "id": "l16-d02",
        "japanese": "受付で この 紙を もらって、名前と 住所を 書いてください。",
        "speaker": "Staff",
      },
      {
        "english": "What do I do after filling it out?",
        "grammarIds": [
          "l16-after-action",
        ],
        "id": "l16-d03",
        "japanese": "書いてから、何を しますか。",
        "speaker": "Tariq",
      },
      {
        "english": "After receiving your card, go to the locker room on the second floor.",
        "grammarIds": [
          "l16-after-action",
        ],
        "id": "l16-d04",
        "japanese": "カードを もらってから、二階の ロッカー室へ 行きます。",
        "speaker": "Staff",
      },
      {
        "english": "How do I get to the pool?",
        "grammarIds": [
          "l16-how-to",
        ],
        "id": "l16-d05",
        "japanese": "プールへは どうやって 行きますか。",
        "speaker": "Tariq",
      },
      {
        "english": "Go up the stairs, turn right, and go straight.",
        "grammarIds": [
          "l16-action-sequence",
        ],
        "id": "l16-d06",
        "japanese": "かいだんを 上がって、右へ まがって、まっすぐ 行ってください。",
        "speaker": "Staff",
      },
      {
        "english": "Thank you. This gym is spacious and bright.",
        "grammarIds": [
          "l16-description-linking",
        ],
        "id": "l16-d07",
        "japanese": "ありがとうございます。この ジムは 広くて、明るいですね。",
        "speaker": "Tariq",
      },
    ],
    "exerciseIds": [
      "l16-e01",
      "l16-e02",
      "l16-e03",
      "l16-e04",
      "l16-e05",
      "l16-e06",
      "l16-e07",
      "l16-e08",
    ],
    "lessonId": "lesson-16",
  },
  {
    "dialogue": [
      {
        "english": "Does your leg still hurt?",
        "grammarIds": [],
        "id": "l17-d01",
        "japanese": "足は まだ いたいですか。",
        "speaker": "Doctor",
      },
      {
        "english": "Yes, it hurts a little. May I go to work tomorrow?",
        "grammarIds": [],
        "id": "l17-d02",
        "japanese": "はい、少し いたいです。あした 仕事へ 行っても いいですか。",
        "speaker": "Luca",
      },
      {
        "english": "Please do not overdo it tomorrow. You must rest at home.",
        "grammarIds": [
          "l17-negative-request",
          "l17-obligation",
        ],
        "id": "l17-d03",
        "japanese": "あしたは むりを しないでください。家で 休まなければ なりません。",
        "speaker": "Doctor",
      },
      {
        "english": "Understood. When should I take the medicine?",
        "grammarIds": [],
        "id": "l17-d04",
        "japanese": "わかりました。くすりは いつ 飲みますか。",
        "speaker": "Luca",
      },
      {
        "english": "You must take it after breakfast and dinner. You do not need to take it at lunchtime.",
        "grammarIds": [
          "l17-obligation",
          "l17-not-necessary",
        ],
        "id": "l17-d05",
        "japanese": "朝ごはんと 晩ごはんの あとで 飲まなければ なりません。お昼は 飲まなくても いいです。",
        "speaker": "Doctor",
      },
      {
        "english": "Do I have to make the next appointment today?",
        "grammarIds": [
          "l17-obligation",
        ],
        "id": "l17-d06",
        "japanese": "つぎの よやくは きょう しなければ なりませんか。",
        "speaker": "Luca",
      },
      {
        "english": "No, you do not have to do it today. Please call next week. Also, please do not forget your insurance card.",
        "grammarIds": [
          "l17-not-necessary",
          "l17-negative-request",
        ],
        "id": "l17-d07",
        "japanese": "いいえ、きょうは しなくても いいです。来週、電話してください。それから、ほけんしょうを わすれないでください。",
        "speaker": "Doctor",
      },
      {
        "english": "Okay. Thank you very much.",
        "grammarIds": [],
        "id": "l17-d08",
        "japanese": "はい。ありがとうございました。",
        "speaker": "Luca",
      },
    ],
    "exerciseIds": [
      "l17-e01",
      "l17-e02",
      "l17-e03",
      "l17-e04",
      "l17-e05",
      "l17-e06",
      "l17-e07",
      "l17-e08",
    ],
    "lessonId": "lesson-17",
  },
  {
    "dialogue": [
      {
        "english": "Will you join Sunday’s exchange gathering?",
        "grammarIds": [],
        "id": "l18-d01",
        "japanese": "にちようびの こうりゅうかいに さんかしますか。",
        "speaker": "Aya",
      },
      {
        "english": "Yes. But what should I present?",
        "grammarIds": [],
        "id": "l18-d02",
        "japanese": "はい。でも、なにを しょうかいしましょうか。",
        "speaker": "Leo",
      },
      {
        "english": "Leo, can you play any instrument?",
        "grammarIds": [
          "l18-ability",
        ],
        "id": "l18-d03",
        "japanese": "レオさんは なにか がっきを ひくことが できますか。",
        "speaker": "Aya",
      },
      {
        "english": "I can play guitar. My hobby is writing songs.",
        "grammarIds": [
          "l18-ability",
          "l18-hobby",
        ],
        "id": "l18-d04",
        "japanese": "ギターを ひくことが できます。しゅみは うたを つくることです。",
        "speaker": "Leo",
      },
      {
        "english": "That sounds great. Shall we practice together before the gathering?",
        "grammarIds": [
          "l18-before",
        ],
        "id": "l18-d05",
        "japanese": "すてきですね。こうりゅうかいの まえに、いっしょに れんしゅうしませんか。",
        "speaker": "Aya",
      },
      {
        "english": "Definitely. Before we practice, I’ll reserve a room.",
        "grammarIds": [
          "l18-before",
        ],
        "id": "l18-d06",
        "japanese": "ぜひ。れんしゅうする まえに、へやを よやくします。",
        "speaker": "Leo",
      },
    ],
