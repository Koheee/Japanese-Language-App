  {
    "dialogue": [
      {
        "english": "When using this printer, what do I do first?",
        "grammarIds": [
          "l23-when-forms",
        ],
        "id": "l23-d01",
        "japanese": "この プリンターを つかう とき、まず なにを しますか。",
        "speaker": "Sora",
      },
      {
        "english": "When you are about to use it, first load the paper.",
        "grammarIds": [
          "l23-timing-viewpoint",
        ],
        "id": "l23-d02",
        "japanese": "つかう ときは、はじめに かみを いれてください。",
        "speaker": "Mai",
      },
      {
        "english": "Then, is it this green button?",
        "grammarIds": [],
        "id": "l23-d03",
        "japanese": "それから、この みどりの ボタンですか。",
        "speaker": "Sora",
      },
      {
        "english": "Yes. When you press the button, the printer starts.",
        "grammarIds": [
          "l23-automatic-to",
        ],
        "id": "l23-d04",
        "japanese": "はい。ボタンを おすと、プリンターが うごきます。",
        "speaker": "Mai",
      },
      {
        "english": "What should I do when it makes a strange sound?",
        "grammarIds": [
          "l23-when-forms",
          "l23-timing-viewpoint",
        ],
        "id": "l23-d05",
        "japanese": "へんな おとが した ときは、どうしますか。",
        "speaker": "Sora",
      },
      {
        "english": "Do not touch the machine; call a staff member. During a malfunction, pressing the red button stops it.",
        "grammarIds": [
          "l23-when-forms",
          "l23-automatic-to",
        ],
        "id": "l23-d06",
        "japanese": "きかいに さわらないで、スタッフを よんでください。こしょうの ときは あかい ボタンを おすと、とまります。",
        "speaker": "Mai",
      },
    ],
    "exerciseIds": [
      "l23-e01",
      "l23-e02",
      "l23-e03",
      "l23-e04",
      "l23-e05",
